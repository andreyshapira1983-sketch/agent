# OpenAI (LLM, TTS, Whisper). Программа подставляет OPEN_KEY_API в OPENAI_API_KEY, если задан.
OPENAI_API_KEY=
# OPEN_KEY_API=   # альтернативное имя (если используешь его в .env)

# Telegram-бот: токен от @BotFather (id:token или просто token)
TELEGRAM=

# Уведомления в реальном времени: алерты (tool_slow, performance_alert, patch_failed) и автономные действия.
# Личный чат: числовой chat_id. Группа: отрицательный chat_id (например -1001234567890).
# Если задан — при старте бот сам отправит приветствие («Доброе утро» / «Добрый день» и т.д.) первым.
# Без этой переменной уведомления только в лог и audit. После изменения — перезапустите агента.
# TELEGRAM_ALERTS_CHAT_ID=123456789

# Троттлинг автономных уведомлений: мин. интервал в секундах (по умолчанию 60). 0 = без ограничения.
# TELEGRAM_ALERTS_MIN_INTERVAL_SEC=60

# Отключить автономные события в Telegram (1 = вкл, 0 = выкл).
# TELEGRAM_AUTONOMOUS_EVENTS=1

# Какие шаги слать в Telegram: cycle, goal, task_start, patch, report (через запятую). Пусто = только итоги цикла.
# task_start,patch,report = короткие сообщения «Начал: X», «Применил патч», «Сгенерировал отчёт».
# TELEGRAM_EVENT_TYPES=task_start,patch,report
# Мин. интервал между шаговыми уведомлениями в сек (по умолчанию 10).
# TELEGRAM_STEP_INTERVAL_SEC=10

# Автомат: при старте бота сразу запустить автономный режим (циклы в фоне, отчёты в Telegram). Остановить: /stop
# AUTONOMOUS_START=1

# При старте сразу включить «только песочница» — не нужно писать /apply_sandbox_only в Telegram.
# APPLY_SANDBOX_ONLY=1
# SAFE_EXPAND=1

# Температура инициативы (0.0–1.0): как часто агент решает написать в Telegram без команды. 0 = никогда, 1 = всегда при разрешённом интервале.
# INITIATIVE_TEMPERATURE=0.7

# Порог «Tool slow» в секундах. Если инструмент выполняется дольше — в Telegram приходит предупреждение. Для validate_patch и run_pytest порог не ниже 25 с (песочница долгая по смыслу).
# TOOL_SLOW_THRESHOLD_SEC=5

# Один раз при старте: собрать индекс кода + эмбеддинги в фоне. Агент сможет искать по коду («какие модули за X»). Писать ничего не нужно — только добавить эту строку и запустить.
# BUILD_CODE_INDEX=1

# Веб-дашборд: граф состояния агента (http://127.0.0.1:8765/dashboard/)
# DASHBOARD=1
# DASHBOARD_PORT=8765

# Режим агента: 1 = нейтральная «семейная» подача, без излишней эмоциональности.
# AGENT_NEUTRAL_FAMILY_MODE=1

# Строгий режим: ограничения на инструменты (write_file, accept_patch и т.д.).
# AGENT_STRICT_MODE=1
