# Copy to .env and edit locally. Never commit .env.

# Provider: mock (safe default) | openai | anthropic
AGENT_PROVIDER=mock

# API keys (required when AGENT_PROVIDER is not mock)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Default model when registry does not override
# AGENT_MODEL=

# Routing policy: offline | balanced | quality (see :models)
# AGENT_MODEL_POLICY=balanced

# Per-session caps (0 = not enforced)
# AGENT_MODEL_MAX_CALLS_PER_SESSION=0
# AGENT_MODEL_MAX_TOKENS_PER_SESSION=0
# AGENT_MODEL_MAX_COST_UNITS_PER_SESSION=0

# Persistent hour/day budget overrides (optional; or use config/budget_limits.json)
# AGENT_BUDGET_HOUR_LLM_CALLS=20
# AGENT_BUDGET_DAY_LLM_CALLS=100
# AGENT_BUDGET_DAY_MODEL_TOKENS=300000
# AGENT_BUDGET_DAY_MODEL_COST_UNITS=500

# Daemon tick (agent_tick.py)
# AGENT_WORKSPACE=.
# AGENT_TICK_DRY_RUN=1
# AGENT_TICK_INTERVAL_SECONDS=1800
