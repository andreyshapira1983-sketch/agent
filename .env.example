# Copy to .env and edit locally. Never commit .env.

# Provider: mock (safe default) | openai | anthropic | huggingface | local
AGENT_PROVIDER=mock

# API keys (required when AGENT_PROVIDER is not mock)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# HF_TOKEN=

# OpenAI-compatible local server (LM Studio / llmster / vLLM / llama.cpp)
# LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_LLM_API_KEY=lm-studio
# LOCAL_LLM_MODEL=qwen-local
# LOCAL_LLM_LOAD_KEY=qwen/qwen3-4b-2507
# LOCAL_LLM_TIMEOUT=60
# Autostart after Windows logon:
#   .\scripts\install_local_llm.ps1
#   (or enable LM Studio "Run LLM service on login")

# Cheap roles on local; keep planner/synthesizer on cloud
# AGENT_MEMORY_PROVIDER=local
# AGENT_MEMORY_MODEL=qwen-local
# AGENT_VERIFIER_PROVIDER=local
# AGENT_VERIFIER_MODEL=qwen-local
# AGENT_REPAIR_PROVIDER=local
# AGENT_REPAIR_MODEL=qwen-local

# Default model when registry does not override
# AGENT_MODEL=

# Routing policy: offline | balanced | quality (see :models)
# AGENT_MODEL_POLICY=balanced

# Per-session caps (0 = not enforced)
# AGENT_MODEL_MAX_CALLS_PER_SESSION=0
# AGENT_MODEL_MAX_TOKENS_PER_SESSION=0
# AGENT_MODEL_MAX_COST_UNITS_PER_SESSION=0

# Persistent hour/day budget overrides (optional; or use config/budget_limits.json)
# AGENT_BUDGET_HOUR_LLM_CALLS=20
# AGENT_BUDGET_DAY_LLM_CALLS=100
# AGENT_BUDGET_DAY_MODEL_TOKENS=300000
# AGENT_BUDGET_DAY_MODEL_COST_UNITS=500

# Daemon tick (agent_tick.py)
# AGENT_WORKSPACE=.
# AGENT_TICK_DRY_RUN=1
# AGENT_TICK_INTERVAL_SECONDS=1800

# Automatic memory hygiene on the unattended path (expire / dedupe / prune /
# archive). The pass DELETES, so it ships in report-only mode: read the
# `maintenance_pass` lines in the tick log before enabling enforcement.
#   shadow  (default) count and log what would be removed, remove nothing
#   on                actually remove
#   off               skip the pass entirely
# `:audit` and a dry-run tick stop it regardless of this setting.
# AGENT_AUTO_HYGIENE=shadow

# Full pytest via run_tests (default 300s; suite is ~3 min)
# AGENT_TEST_TIMEOUT_SECONDS=300
