.env
.env.*
!.env.example

config/credentials.json
config/token.json
config/budget_limits.json
config/*.secret.json
!config/*.example.json

# Private keys, certificates & OAuth client secrets — never commit these.
# (release_hygiene.py rejects them at packaging time; this stops the accidental
#  commit one step earlier.)
*.pem
*.key
*.p12
*.pfx
*.keystore
client_secret*.json
id_rsa
id_dsa
id_ecdsa
id_ed25519

data/
logs/

# Throwaway agent workspaces used for live probes (e.g. runtime/mir003-live).
# Each holds its own data/ and logs/ — already covered by the rules above — but
# also probe fixtures and answers, which are local experiment artefacts, not
# repository content. Ignoring the whole tree keeps a stray `git add -A` from
# committing a live run's inputs and outputs.
runtime/

__pycache__/
*.py[cod]
.pytest_cache/
pytest-tmp/
.coverage
htmlcov/

.venv/
venv/
env/

# Visual Studio / VS Code workspace state
.vs/

*.tmp
*.bak
*.log

.vscode/
.codex/
config/model_registry.json
