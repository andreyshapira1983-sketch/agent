# Минимальный sandbox-образ для безопасного исполнения кода агентом.
# Цель: полная изоляция от хост-системы.
#
# Сборка:  docker build -t agent-sandbox -f Dockerfile.sandbox .
# Запуск:  docker run --rm --read-only --network none --memory 256m \
#            --cpus 1 --user nobody --pids-limit 64 \
#            --no-new-privileges agent-sandbox python -c "print('ok')"
#
# Принципы:
#   - ТОЛЬКО Python и базовые утилиты (git, grep, find)
#   - Нет curl/wget/ssh/bash (shell удалён)
#   - Нет доступа к хост-сети (--network none при запуске)
#   - Нет привилегированных операций
#   - Файловая система read-only (--read-only при запуске)
#   - /tmp доступен для записи (tmpfs)

FROM python:3.13-slim AS builder

# Устанавливаем только необходимые пакеты
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Копируем и ставим зависимости
COPY config/requirements.lock /tmp/requirements.lock
RUN pip install --no-cache-dir -r /tmp/requirements.lock \
    && rm /tmp/requirements.lock

# ─── Runtime stage ──────────────────────────────────────────────────────────

FROM python:3.13-slim

# Минимальные системные пакеты
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Копируем установленные Python-пакеты из builder
COPY --from=builder /usr/local/lib/python3.13/site-packages /usr/local/lib/python3.13/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# SECURITY: удаляем shell-доступ и опасные утилиты
RUN rm -f /bin/sh /bin/bash /usr/bin/curl /usr/bin/wget \
    /usr/bin/nc /usr/bin/ncat /usr/bin/ssh /usr/bin/scp \
    /usr/bin/apt /usr/bin/apt-get /usr/bin/dpkg \
    && ln -s /bin/true /bin/sh

# Создаём рабочую директорию
WORKDIR /workspace

# Копируем код агента (read-only в runtime)
COPY . /workspace/

# SECURITY: непривилегированный пользователь
RUN useradd --no-create-home --shell /bin/false sandbox \
    && chown -R sandbox:sandbox /workspace

USER sandbox

# Healthcheck
HEALTHCHECK --interval=30s --timeout=5s --retries=1 \
    CMD python -c "print('ok')" || exit 1

# Точка входа по умолчанию
ENTRYPOINT ["python"]
CMD ["--version"]
